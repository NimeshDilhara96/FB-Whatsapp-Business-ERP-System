# Backend API Port
PORT=5000

# Multi-Tenancy Configuration
IS_MULTI_TENANT=true
DEFAULT_TENANT_ID=default-company

# Security Secrets (Replace these with strong, randomly generated hex strings in production)
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Database Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Frontend URL (Important for CORS)
# Use http://localhost:5173 for local development
# Use your Vercel URL for production (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173
